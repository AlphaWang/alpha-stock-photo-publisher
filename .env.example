# Copy this file to .env and fill in your values. Never commit .env.

# Option A — Internal gateway (company network)
CLAUDE_GATEWAY_URL=https://<internal-gateway-host>/v1/anthropic
CLAUDE_TOKEN_CMD=npx @ebay/claude-code-token@latest get_token

# Option B — Standard Anthropic API (external / personal use)
# ANTHROPIC_API_KEY=sk-ant-...
